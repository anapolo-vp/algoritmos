#Somatório Simples

cont = 0 
soma = 0
media = 0
print ('Insira 5 números: ')
while cont <5:
    cont += 1
    num = int (input())
    soma += num
    media = soma / cont

print (f'A soma total é {soma} e a média é {media} ')


