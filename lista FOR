##5. n vezes o seguinte processamento: receba 3 valores e faça a média

n = int (input('Número de vezes a realizar a média: '))
for i in range (n):
    num1 = float (input ('Digite o 1° valor: '))
    num2 = float (input ('Digite o 2° valor: '))
    num3 = float (input ('Digite o 3° valor: '))
    media = (num1 + num2 + num3) / 3
    print (f'A média desses valores é {media:.2f}')

